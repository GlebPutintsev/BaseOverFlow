DEBUG=false
SECRET_KEY=your-secret-key-change-in-production
FRONTEND_PORT=80

# URL подключения к PostgreSQL
# Формат: postgresql+asyncpg://user:password@host:5432/database
#
# Postgres на ноутбуке, приложение в Docker — используйте host.docker.internal:
DATABASE_URL=postgresql+asyncpg://postgres:postgres@host.docker.internal:5432/baseoverflow
#
# Другие варианты:
# - Postgres на другом сервере → IP или домен сервера вместо host.docker.internal
# - Запуск без Docker (локально) → localhost вместо host.docker.internal

# После смены БД или если поиск не находит записи — принудительный реиндекс Qdrant при старте (1 = да)
# FORCE_REINDEX=1

# Qdrant (векторный поиск): URL инстанса. Без него векторный поиск отключён (в логах будет предупреждение).
# Контейнер в той же сети: http://qdrant:6333
# Qdrant на хосте: http://host.docker.internal:6333
# QDRANT_URL=http://qdrant:6333
